{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "mulch prime"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/session_start.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/session_local.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "mulch prime"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/session_start.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/session_local.sh"
          }
        ]
      }
    ]
  }
