# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ Felt Like It — Production Environment                                       │
# │                                                                             │
# │ Copy to docker/.env and fill in required values.                            │
# │ Or run: ./setup.sh (generates secrets automatically)                        │
# └─────────────────────────────────────────────────────────────────────────────┘

# ── Domain & TLS ───────────────────────────────────────────────────────────────
# Your public domain (e.g., maps.example.com). Used for Traefik routing + ORIGIN.
DOMAIN=maps.example.com

# Email for Let's Encrypt certificate notifications.
ACME_EMAIL=admin@example.com

# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_USER=felt
POSTGRES_DB=felt

# Generate with: openssl rand -hex 32
POSTGRES_PASSWORD=

# ── Application ────────────────────────────────────────────────────────────────
# Must match https://${DOMAIN} for cookie security.
ORIGIN=https://maps.example.com

# Generate with: openssl rand -hex 32
SESSION_SECRET=

# Log level: debug, info, warn, error
LOG_LEVEL=info

# ── Redis ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
REDIS_PASSWORD=

# ── Geocoding (optional) ──────────────────────────────────────────────────────
# Self-hosted Nominatim URL. Leave commented to use official OSM Nominatim
# (max 1 req/s, no bulk use allowed).
# NOMINATIM_URL=http://nominatim:8080
# GEOCODING_USER_AGENT=felt-like-it/1.0
