# ── Stage 1: Install dependencies ─────────────────────────────────────────────
FROM node:22-alpine AS deps
WORKDIR /app

# Install pnpm
RUN corepack enable && corepack prepare pnpm@9.15.4 --activate

# Copy workspace manifests
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY packages/shared-types/package.json ./packages/shared-types/
COPY packages/geo-engine/package.json ./packages/geo-engine/
COPY packages/import-engine/package.json ./packages/import-engine/
COPY apps/web/package.json ./apps/web/
COPY services/worker/package.json ./services/worker/

# Install all dependencies (needed for build)
RUN pnpm install --frozen-lockfile

# ── Stage 2: Build ─────────────────────────────────────────────────────────────
FROM deps AS builder
WORKDIR /app

# Copy all source files
COPY . .

# Build the SvelteKit app
RUN pnpm --filter @felt-like-it/web build

# ── Stage 2b: Prune to runtime deps ────────────────────────────────────────────
# Reuse the install + build from `builder`; `pnpm deploy` produces a
# self-contained directory with only @felt-like-it/web's production deps,
# avoiding the second `pnpm install` we used to run in the runner stage.
FROM builder AS pruner
WORKDIR /app
RUN pnpm --filter @felt-like-it/web deploy --prod --legacy /deploy

# ── Stage 3: Production image ──────────────────────────────────────────────────
FROM node:22-alpine AS runner
WORKDIR /app

# Production runtime deps (already pruned, no pnpm needed at runtime).
COPY --from=pruner /deploy/node_modules ./apps/web/node_modules
COPY --from=pruner /deploy/package.json ./apps/web/package.json

# Copy built app
COPY --from=builder /app/apps/web/build ./apps/web/build
COPY --from=builder /app/packages/shared-types/src ./packages/shared-types/src
COPY --from=builder /app/packages/geo-engine/src ./packages/geo-engine/src

# Copy migration SQL for startup
COPY apps/web/src/lib/server/db/migrations ./apps/web/migrations

# Entrypoint: auto-migrate, seed, then start
COPY docker/migrate.mjs /app/migrate.mjs
COPY docker/seed.mjs /app/seed.mjs
COPY docker/docker-entrypoint.sh /app/docker-entrypoint.sh
RUN chmod +x /app/docker-entrypoint.sh

# pg_isready for health wait
RUN apk add --no-cache postgresql-client

# Create uploads directory
RUN mkdir -p /uploads

# Non-root user for security
RUN addgroup -g 1001 -S nodejs && adduser -S sveltekit -u 1001
RUN chown -R sveltekit:nodejs /uploads
USER sveltekit

EXPOSE 3000

ENV NODE_ENV=production
ENV UPLOAD_DIR=/uploads
ENV PORT=3000
ENV MIGRATIONS_DIR=/app/apps/web/migrations

ENTRYPOINT ["/app/docker-entrypoint.sh"]
CMD ["node", "apps/web/build/index.js"]
