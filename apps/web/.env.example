# Example environment for apps/web. Copy to `.env` (or `.env.local` for
# overrides) and fill in real values. NEVER commit secrets — placeholders only.

# ── Server (private) ──────────────────────────────────────────────────────────

# PostgreSQL connection string used by the server-side Drizzle pool.
DATABASE_URL=postgresql://felt:felt@localhost:5432/felt

# Optional Drizzle pool tuning. Defaults: max=20, statement_timeout=10000ms.
# DB_POOL_MAX=20
# DB_STATEMENT_TIMEOUT_MS=10000

# Redis connection string (BullMQ jobs + rate limiting).
REDIS_URL=redis://localhost:6379

# Filesystem location for uploaded files (imports, annotation images, etc).
UPLOAD_DIR=/tmp/felt-uploads

# Public origin SvelteKit serves from. Used to gate Secure cookies (https://...).
ORIGIN=http://localhost:5173

# Lucia session cookie secret. Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-generate-with-openssl-rand-hex-32

# Nominatim geocoding endpoint (used by CSV import with address columns).
# Defaults to the official OSM Nominatim — set a self-hosted instance for
# production or high-volume use (official Nominatim: max 1 req/s, no bulk use).
# NOMINATIM_URL=http://localhost:8088

# User-Agent string Nominatim requires. Include contact info in production.
GEOCODING_USER_AGENT=felt-like-it/1.0 (dev)

# Rate limit for API keys (requests per second per key).
API_RATE_LIMIT=100

# Per-user concurrent SSE stream cap for /api/v1/export/progress.
# EXPORT_SSE_STREAM_CAP=5

# Idle timeout for SSE export-progress streams (ms). Default 5 min.
# EXPORT_SSE_IDLE_MS=300000

# Hold window for error-path slot release on SSE export-progress (ms).
# EXPORT_SSE_ERROR_HOLD_MS=500

# ── Build / version ───────────────────────────────────────────────────────────

# Surfaced via `kit.version.name` for client-side invalidation + diagnostics.
# Set by CI (e.g., short SHA). Falls back to build-time ISO timestamp when unset.
# PUBLIC_BUILD_VERSION=

# ── Client (public — bundled into browser code) ───────────────────────────────

# Martin tile server URL. Browser-facing.
# Set to empty string to disable vector tile mode (all layers render as GeoJSON).
PUBLIC_MARTIN_URL=http://localhost:3001
